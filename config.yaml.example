providers:
  - name: nvidia-nim
    base_url: "https://api.nvcf.nvidia.com/v1"
    api_key: "${NVIDIA_NIM_API_KEY}"
    models: []
    # Add explicit model metadata before routing production traffic.
    # The router does not infer capabilities, context length, price, or latency from /models.
    #
    # models:
    #   - id: "provider-published-model-id"
    #     provider: nvidia-nim
    #     capabilities:
    #       context_length: 128000
    #       reasoning_strength: 0.8
    #       coding_strength: 0.7
    #       tool_calling: true
    #       multimodal: false
    #     cost_per_1k_tokens: null # replace with provider-published effective price
    #     latency_score: null # optional measured p50/p95-derived seconds
    #     health_status: healthy
  - name: openrouter
    base_url: "https://openrouter.ai/api/v1"
    api_key: "${OPENROUTER_API_KEY}"
    models: []
  - name: groq
    base_url: "https://api.groq.com/openai/v1"
    api_key: "${GROQ_API_KEY}"
    models: []
  - name: gemini
    base_url: "https://generativelanguage.googleapis.com/v1beta"
    api_key: "${GEMINI_API_KEY}"
    models: []

routing_policy:
  strategy: adaptive
  weights:
    latency: 0.3
    cost: 0.3
    capability: 0.4
    reliability: 0.0

security:
  max_prompt_chars: 200000
  block_prompt_injection_signals: true
  redact_request_content_in_logs: true

cache_enabled: True
redis_url: "${REDIS_URL}"
log_level: INFO
