#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@puppeteer/browsers/2.13.2/ccd38988b37b60cf6111f2893bff8ebe0fdd03f95727bf178d3d3e7224c8eeee/node_modules/@puppeteer/browsers/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@puppeteer/browsers/2.13.2/ccd38988b37b60cf6111f2893bff8ebe0fdd03f95727bf178d3d3e7224c8eeee/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19e6d845a7d/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@puppeteer/browsers/2.13.2/ccd38988b37b60cf6111f2893bff8ebe0fdd03f95727bf178d3d3e7224c8eeee/node_modules/@puppeteer/browsers/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@puppeteer/browsers/2.13.2/ccd38988b37b60cf6111f2893bff8ebe0fdd03f95727bf178d3d3e7224c8eeee/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19e6d845a7d/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../lib/cjs/main-cli.js" "$@"
else
  exec node  "$basedir/../../lib/cjs/main-cli.js" "$@"
fi
