#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@/yarn/1.22.22/7aebf8334d986e9857d2c52decaa1fa3fcfdad94dea993402b513156449d9691/node_modules/yarn/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@/yarn/1.22.22/7aebf8334d986e9857d2c52decaa1fa3fcfdad94dea993402b513156449d9691/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19e6d84593d/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@/yarn/1.22.22/7aebf8334d986e9857d2c52decaa1fa3fcfdad94dea993402b513156449d9691/node_modules/yarn/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@/yarn/1.22.22/7aebf8334d986e9857d2c52decaa1fa3fcfdad94dea993402b513156449d9691/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19e6d84593d/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/yarn.js" "$@"
else
  exec node  "$basedir/../../bin/yarn.js" "$@"
fi
