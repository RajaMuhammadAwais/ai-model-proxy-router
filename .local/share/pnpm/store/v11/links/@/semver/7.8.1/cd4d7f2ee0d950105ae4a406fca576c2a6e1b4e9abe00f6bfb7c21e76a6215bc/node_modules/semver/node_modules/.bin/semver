#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@/semver/7.8.1/cd4d7f2ee0d950105ae4a406fca576c2a6e1b4e9abe00f6bfb7c21e76a6215bc/node_modules/semver/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@/semver/7.8.1/cd4d7f2ee0d950105ae4a406fca576c2a6e1b4e9abe00f6bfb7c21e76a6215bc/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19e6d845a7d/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@/semver/7.8.1/cd4d7f2ee0d950105ae4a406fca576c2a6e1b4e9abe00f6bfb7c21e76a6215bc/node_modules/semver/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@/semver/7.8.1/cd4d7f2ee0d950105ae4a406fca576c2a6e1b4e9abe00f6bfb7c21e76a6215bc/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19e6d845a7d/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/semver.js" "$@"
else
  exec node  "$basedir/../../bin/semver.js" "$@"
fi
