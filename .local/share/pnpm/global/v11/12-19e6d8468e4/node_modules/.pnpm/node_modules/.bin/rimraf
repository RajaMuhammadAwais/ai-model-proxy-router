#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@/rimraf/6.1.3/1eabd6aff45d5c7aed02c2c2db69a4fc5d410cf5c31202bafecfbc7c877e420a/node_modules/rimraf/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@/rimraf/6.1.3/1eabd6aff45d5c7aed02c2c2db69a4fc5d410cf5c31202bafecfbc7c877e420a/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19e6d8468e4/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@/rimraf/6.1.3/1eabd6aff45d5c7aed02c2c2db69a4fc5d410cf5c31202bafecfbc7c877e420a/node_modules/rimraf/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@/rimraf/6.1.3/1eabd6aff45d5c7aed02c2c2db69a4fc5d410cf5c31202bafecfbc7c877e420a/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19e6d8468e4/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../rimraf/dist/esm/bin.mjs" "$@"
else
  exec node  "$basedir/../rimraf/dist/esm/bin.mjs" "$@"
fi
