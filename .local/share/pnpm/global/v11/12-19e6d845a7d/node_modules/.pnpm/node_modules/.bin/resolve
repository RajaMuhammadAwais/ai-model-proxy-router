else
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@/resolve/1.22.12/3f1374bc4ae6397e3707fa52b1eeeec51a7545f630b2cfaa7fc4c8479a87a8a1/node_modules/resolve/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@/resolve/1.22.12/3f1374bc4ae6397e3707fa52b1eeeec51a7545f630b2cfaa7fc4c8479a87a8a1/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19e6d845a7d/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../resolve/bin/resolve" "$@"
else
  exec node  "$basedir/../resolve/bin/resolve" "$@"
fi
