#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@/uuid/14.0.0/84b957ef0d187716534139c73be9d159edf46a15ad2dc63c9a95a87b73304345/node_modules/uuid/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@/uuid/14.0.0/84b957ef0d187716534139c73be9d159edf46a15ad2dc63c9a95a87b73304345/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19e6d845a7d/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@/uuid/14.0.0/84b957ef0d187716534139c73be9d159edf46a15ad2dc63c9a95a87b73304345/node_modules/uuid/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@/uuid/14.0.0/84b957ef0d187716534139c73be9d159edf46a15ad2dc63c9a95a87b73304345/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19e6d845a7d/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../uuid/dist-node/bin/uuid" "$@"
else
  exec node  "$basedir/../uuid/dist-node/bin/uuid" "$@"
fi
