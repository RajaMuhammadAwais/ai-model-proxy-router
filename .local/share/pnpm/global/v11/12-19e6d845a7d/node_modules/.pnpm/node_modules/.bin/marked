else
  export NODE_PATH="/home/ubuntu/.local/share/pnpm/store/v11/links/@/marked/16.4.2/292e6a58d319c865053772afc3f96ff7290520ffb9cd7caa6c0d638b38119524/node_modules/marked/node_modules:/home/ubuntu/.local/share/pnpm/store/v11/links/@/marked/16.4.2/292e6a58d319c865053772afc3f96ff7290520ffb9cd7caa6c0d638b38119524/node_modules:/home/ubuntu/.local/share/pnpm/global/v11/12-19e6d845a7d/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../marked/bin/marked.js" "$@"
